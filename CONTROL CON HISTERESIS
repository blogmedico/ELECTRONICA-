<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simulador Cooler NTC 41k LM358 - PRO</title>

<style>
body { font-family: Arial; background:#0f172a; color:white; margin:0; padding:20px; }
h1 { text-align:center; }
.container { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
.card { background:#1e293b; padding:20px; border-radius:12px; box-shadow:0 0 15px rgba(0,0,0,0.5); }
input[type=range]{ width:100%; }
.value{ margin:5px 0; font-size:18px; }

.protoboard { background:#e5e7eb; height:450px; border-radius:10px; position:relative; padding:20px; }
.chip { position:absolute; top:170px; left:220px; width:120px; height:80px; background:black; border-radius:5px; text-align:center; line-height:80px; font-size:12px; }
.ntc { position:absolute; top:60px; left:60px; width:60px; height:20px; background:orange; border-radius:5px; text-align:center; color:black; font-size:12px; }
.res { position:absolute; width:60px; height:20px; background:#fbbf24; border-radius:5px; text-align:center; color:black; font-size:12px; }
.transistor { position:absolute; top:220px; right:160px; width:40px; height:40px; background:#333; border-radius:5px; text-align:center; font-size:10px; }
.diode { position:absolute; top:200px; right:100px; width:40px; height:20px; background:#999; border-radius:5px; text-align:center; font-size:10px; }
.cooler { position:absolute; top:170px; right:40px; width:80px; height:80px; border-radius:50%; background:gray; display:flex; align-items:center; justify-content:center; }
.fan { width:40px; height:40px; border-radius:50%; background:black; }
.spin { animation:spin 0.4s linear infinite; }
@keyframes spin { from{transform:rotate(0)} to{transform:rotate(360deg)} }

.led{ position:absolute; width:20px; height:20px; border-radius:50%; background:#222; border:2px solid black; }
.on{ background:red; box-shadow:0 0 10px red; }
.on-green{ background:lime; box-shadow:0 0 10px lime; }
.off{ background:#222; }
.label{ position:absolute; font-size:12px; color:black; }

.wire-red{ position:absolute; height:4px; background:red; }
.wire-black{ position:absolute; height:4px; background:black; }
.wire-blue{ position:absolute; height:4px; background:blue; }

</style>
</head>

<body>
<h1>Simulador Cooler NTC 41k + LM358 (PRO)</h1>

<div class="container">

<div class="card">
<h3>Control de temperatura</h3>
<input type="range" min="20" max="80" value="25" id="temp" oninput="simular()">
<div class="value">Temperatura: <span id="tempVal">25</span> °C</div>
<div class="value">NTC: <span id="ntcVal"></span> Ω</div>
<div class="value">Pin2: <span id="vinv"></span> V</div>
<div class="value">Pin3: <span id="vref"></span> V</div>
<div class="value">Salida: <span id="vout"></span> V</div>
<div class="value">Estado: <span id="estadoTxt"></span></div>
<p>Encendido: 60°C | Apagado: 40°C</p>
</div>

<div class="card">
<h3>Protoboard</h3>
<div class="protoboard">

<div class="chip">LM358</div>
<div class="ntc">NTC</div>

<div class="res" style="top:30px; left:60px;">10k</div>
<div class="res" style="top:110px; left:220px;">10k</div>
<div class="res" style="top:140px; left:220px;">10k</div>
<div class="res" style="top:200px; left:220px;">10k</div>

<div class="transistor">2N2222</div>
<div class="diode">D</div>

<div class="cooler"><div class="fan" id="fan"></div></div>

<!-- wires -->
<div class="wire-red" style="top:40px; left:60px; width:250px;"></div>
<div class="wire-black" style="top:260px; left:60px; width:300px;"></div>
<div class="wire-blue" style="top:120px; left:120px; width:200px;"></div>

<!-- leds -->
<div class="led" id="ledSensor" style="top:70px; left:140px;"></div>
<div class="label" style="top:50px; left:135px;">Sensor</div>

<div class="led" id="ledRef" style="top:130px; left:150px;"></div>
<div class="label" style="top:110px; left:145px;">Ref</div>

<div class="led" id="ledOut" style="top:200px; left:150px;"></div>
<div class="label" style="top:180px; left:145px;">Salida</div>

<div class="led" id="ledCooler" style="top:220px; right:120px;"></div>
<div class="label" style="top:200px; right:110px;">Cooler</div>

</div>
</div>
</div>

<script>
let estado = 0;

function ntc(temp){
 let R25=41000; let beta=3950; let T0=298.15; let T=temp+273.15;
 return R25*Math.exp(beta*(1/T-1/T0));
}

function simular(){
 let temp=parseFloat(document.getElementById("temp").value);
 document.getElementById("tempVal").innerHTML=temp;

 let Rntc=ntc(temp);
 document.getElementById("ntcVal").innerHTML=Rntc.toFixed(0);

 let Vcc=12; let R1=10000;
 let Vinv=Vcc*(Rntc/(R1+Rntc));

 let Vref_on=6.5;
 let Vref_off=8.0;

 if(estado===0 && Vinv<=Vref_on) estado=1;
 if(estado===1 && Vinv>=Vref_off) estado=0;

 let Vref=estado?Vref_on:Vref_off;
 let Vout=estado?12:0;

 document.getElementById("vinv").innerHTML=Vinv.toFixed(2);
 document.getElementById("vref").innerHTML=Vref.toFixed(2);
 document.getElementById("vout").innerHTML=Vout.toFixed(2);

 let fan=document.getElementById("fan");
 let estadoTxt=document.getElementById("estadoTxt");

 let ledSensor=document.getElementById("ledSensor");
 let ledRef=document.getElementById("ledRef");
 let ledOut=document.getElementById("ledOut");
 let ledCooler=document.getElementById("ledCooler");

 if(Vinv<7) ledSensor.className="led on"; else ledSensor.className="led off";
 if(Vref<7) ledRef.className="led on"; else ledRef.className="led off";

 if(estado){
  fan.classList.add("spin");
  estadoTxt.innerHTML="COOLER ENCENDIDO";
  ledOut.className="led on-green";
  ledCooler.className="led on-green";
 }else{
  fan.classList.remove("spin");
  estadoTxt.innerHTML="COOLER APAGADO";
  ledOut.className="led off";
  ledCooler.className="led off";
 }
}

simular();
</script>

</body>
</html>
